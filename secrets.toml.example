# Streamlit Community Cloud：App settings → Secrets

# 可選：Pinnacle guest API key 變更時才需要設定。
# PINNACLE_API_KEY = "你的 API Key"

# 必填：讓 Streamlit 能建立／覆蓋 GitHub main/today_matches.json。
# 請使用 Fine-grained personal access token，Repository access 指定 tennis-filter，
# Repository permissions 將 Contents 設為 Read and write。
GITHUB_TOKEN = "github_pat_你的Token"
